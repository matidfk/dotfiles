syntax on       " Enable syntax hightlighting
set number
set showmatch
set visualbell
set smartcase
set ignorecase
set incsearch
set autoindent
set shiftwidth=4
set smartindent
set smarttab
set softtabstop=4
set ruler
set clipboard=unnamedplus
set undolevels=1000

let g:airline#extensions#tabline#enabled = 1 " Enable the list of buffers
set noshowmode
set noshowcmd
set shortmess+=F
